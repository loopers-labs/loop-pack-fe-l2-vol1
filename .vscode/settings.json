{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "tailwindCSS.classFunctions": ["tv", "cn", "cx", "cnMerge"],
  "editor.quickSuggestions": {
    "strings": true
  }
}
